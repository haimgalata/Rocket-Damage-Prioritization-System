# Copy keys into repo-root `.env` for Docker Compose (recommended), or merge with [.env.example](../.env.example).
# Do not commit real secrets.

# ML inference base URL — no trailing slash.
# Examples: http://127.0.0.1:8080  |  https://your-ml-service.example.run.app
ML_SERVICE_URL=https://your-ml-service.example.run.app

# Optional: set on both ML service and backend when securing POST /predict.
# ML_SERVICE_API_KEY=
