# ─────────────────────────────────────────────────────────────────────────────
# PrioritAI — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
build/

# ── Machine Learning Models ───────────────────────────────────────────────────
# *.keras is tracked via Git LFS (see .gitattributes) — do NOT add it here.
# Other large model formats that are NOT used in this project:
*.h5
*.pt
*.pth
*.onnx

# ── GIS / OSMnx Cache ─────────────────────────────────────────────────────────
# OSMnx caches Overpass API responses as JSON files — regenerated per environment.
cache/
server/cache/
**/osmnx_cache/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
client/dist/
client/dist-ssr/
*.local

# npm / yarn / pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Environment Variables ─────────────────────────────────────────────────────
# NEVER commit real credentials. Copy .env.example → .env and fill in values.
.env
.env.local
.env.*.local

# ── IDE & Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS Generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Docker runtime volumes (if stored locally) ────────────────────────────────
docker-volumes/

# ── Uploads (repo root + server) ──────────────────────────────────────────────
# Ignore arbitrary uploads; allow only seed/demo assets referenced by server/seed_events.json
# and placeholder fallback (see server/src/seed_db.py).
server/uploads/
uploads/*
!uploads/.gitkeep
!uploads/placeholder_1.jpg
!uploads/tel_aviv_*.jpg
!uploads/jerusalem_*.jpg
!uploads/south_*.jpg

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.cache
*.env
dist/
.next/
backend.log
*.iml