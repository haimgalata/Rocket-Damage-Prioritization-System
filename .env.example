# ─────────────────────────────────────────────────────────────────────────────
# PrioritAI — Environment Variables Template
# Copy this file to `.env` and fill in the values before running the server.
# The `.env` file is loaded automatically by python-dotenv when the app starts.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# Environment mode: "development" | "production"
APP_ENV=development

# Log level for the FastAPI / Uvicorn server.
LOG_LEVEL=info

# ── Database ───────────────────────────────────────────────────────────────────
# Single source of truth for backend DB connection.
# Pick ONE mode:
#
# 1) Supabase mode (recommended):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.gstvhplhwiwjodccggys.supabase.co:5432/postgres?sslmode=require
#
# 2) Local Docker postgres fallback mode:
# DATABASE_URL=postgresql://prioritai:prioritai@postgres:5432/prioritai
#
# Important:
# - Never commit real passwords.
# - If your password contains special characters (@, :, /, #, ?), URL-encode it.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.gstvhplhwiwjodccggys.supabase.co:5432/postgres?sslmode=require

# ── Supabase Storage ────────────────────────────────────────────────────────────
# Used by backend image upload flow (bucket: event-images).
# Never commit real secrets.
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=<SUPABASE_SERVICE_ROLE_OR_ANON_KEY>

# ── Frontend (Vite build-time variable) ───────────────────────────────────────
# URL the browser uses to reach the FastAPI backend. Must be HTTPS in production
# when the site is served over HTTPS (mixed content otherwise).
#
# Local: http://localhost:8000 (or omit and rely on api.ts default).
# Docker Compose: build arg /api (Nginx proxies to backend in compose only).
# Render static site / production CI: set to your public API origin, e.g.
#   https://prioritai-backend.onrender.com
# No trailing slash. This value is baked in at `npm run build`, not runtime.
VITE_API_URL=http://localhost:8000

# ── Groq LLM ───────────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here