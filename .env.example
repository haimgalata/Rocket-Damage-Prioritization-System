# ─────────────────────────────────────────────────────────────────────────────
# PrioritAI — Environment Variables Template
# Copy this file to `.env` and fill in the values before running the stack.
# Docker Compose loads this file for the backend via `env_file: .env`.
# For bare `uvicorn` without Compose, export variables or use a shell that loads `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# Environment mode: "development" | "production"
APP_ENV=development

# Log level for the FastAPI / Uvicorn server (wire-up in code may vary).
LOG_LEVEL=info

# ── Database ───────────────────────────────────────────────────────────────────
# Single source of truth for backend DB connection.
# Pick ONE mode:
#
# 1) Hosted Postgres (e.g. Supabase):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require
#
# 2) Local Docker postgres (see docker-compose.yml service name `postgres`):
# DATABASE_URL=postgresql://prioritai:prioritai@postgres:5432/prioritai
#
# Important:
# - Never commit real passwords.
# - If your password contains special characters (@, :, /, #, ?), URL-encode it.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require

# ── Auth ───────────────────────────────────────────────────────────────────────
# Required in production. Must match the value used to sign and verify JWTs.
JWT_SECRET=change-me-to-a-long-random-string

# ── ML microservice ───────────────────────────────────────────────────────────
# Base URL, no trailing slash. Docker Compose overrides this to http://ml-service:8080 for the backend service.
ML_SERVICE_URL=http://127.0.0.1:8080
# Optional: set the same value on ml-service and backend when securing /predict
# ML_SERVICE_API_KEY=
# ML_SERVICE_CONNECT_TIMEOUT=5
# ML_SERVICE_READ_TIMEOUT=120

# ── Supabase Storage ────────────────────────────────────────────────────────────
# Used by backend image upload flow (bucket: event-images).
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=<SUPABASE_SERVICE_ROLE_OR_ANON_KEY>

# ── Frontend (Vite build-time variable) ───────────────────────────────────────
# URL the browser uses to reach the FastAPI backend. Must be HTTPS in production
# when the site is served over HTTPS (mixed content otherwise).
#
# Local: http://localhost:8000 (or omit and rely on api.ts default).
# Docker Compose: build arg /api (Nginx proxies to backend in compose only).
# Render static site / production CI: set to your public API origin.
# No trailing slash. Baked in at `npm run build`, not runtime.
VITE_API_URL=http://localhost:8000

# ── Groq LLM ───────────────────────────────────────────────────────────────────
# Optional narrative explanations for priority scores.
GROQ_API_KEY=your_groq_api_key_here



# ### Local Docker Configuration (docker compose up)
# Use the following only when running the stack locally with Docker Compose from
# the repo root. Hostnames "postgres" and "ml-service" are Compose *service names*
# (DNS on the internal Docker network), not localhost — they differ from production
# (e.g. Render, Cloud Run, hosted Supabase DB URLs).
#
# Typical .env lines for local Docker:
#   DATABASE_URL=postgresql://prioritai:prioritai@postgres:5432/prioritai
#   ML_SERVICE_URL=http://ml-service:8080
#   VITE_API_URL=/api
#
# VITE_API_URL=/api matches the SPA served at http://localhost with Nginx proxying
# /api to the backend (see docker-compose.yml build args). Do not use these URLs
# for production deployments.